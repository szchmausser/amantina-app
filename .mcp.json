{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "engram": {
            "command": "engram",
            "args": [
                "mcp",
                "--tools=agent"
            ],
            "lifecycle": "lazy",
            "directTools": true
        }
    }
}